#!/bin/bash

# These match your Terraform backend block exactly
RESOURCE_GROUP_NAME="rg-test-mn"
STORAGE_ACCOUNT_NAME="rgtestmn"
CONTAINER_NAME="staty"
LOCATION="eastus"

echo "========================================="
echo "Creating Backend for practice.tfstate"
echo "========================================="

# 1. Create the Resource Group
echo "1. Creating Resource Group: $RESOURCE_GROUP_NAME..."
az group create --name "$RESOURCE_GROUP_NAME" --location "$LOCATION" -o none

# 2. Create the Storage Account
echo "2. Creating Storage Account: $STORAGE_ACCOUNT_NAME..."
az storage account create \
  --resource-group "$RESOURCE_GROUP_NAME" \
  --name "$STORAGE_ACCOUNT_NAME" \
  --sku Standard_LRS \
  --encryption-services blob \
  -o none

# 3. Create the Blob Container
echo "3. Creating Blob Container: $CONTAINER_NAME..."
az storage container create \
  --name "$CONTAINER_NAME" \
  --account-name "$STORAGE_ACCOUNT_NAME" \
  -o none

echo "========================================="
echo "✅ Backend successfully created! You can now run 'terraform init'"
echo "========================================="
